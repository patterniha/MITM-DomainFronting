{
  "__Credits__": {
    "creator": "@patterniha",
    "donate1": "USDT (BEP20): 0x76a768B53Ca77B43086946315f0BDF21156bF424",
    "donate2": "USDT (TRC20): TU5gKvKqcXPn8itp1DouBCwcqGHMemBm8o"
  },


  "remarks": "MITM-DomainFronting_v5",

  "version": {
    "min": "26.2.6"
  },

  "log": {
    "loglevel": "warning", "dnsLog": false, "access": "none"
  },

  "policy": {
    "levels": {
      "0": {
        "uplinkOnly": 0,
        "downlinkOnly": 0
      }
    }
  },

  "dns":{
    "hosts": {
      "geosite:category-ads-all": "#3",
      "google-main-services.redirect": "216.239.38.120",
	  "vercel-sites.redirect": "react.dev",
	  "fastly.redirect": "www.python.org",
	  "amazon-cloudfront.redirect": "kubernetes.io"
    },
    "servers": [
      "fakedns",
	  "localhost"
    ],
    "queryStrategy": "UseSystem",
    "useSystemHosts": true,
    "tag": "dns_inbound"
  },

  "inbounds": [
    {
      "tag": "mixed-in",
      "port": 10808,
      "protocol": "mixed",
      "sniffing": {
        "enabled": true,
        "destOverride": ["fakedns", "tls"],
        "routeOnly": false
      },
      "settings": {
        "udp": true,
        "ip": "127.0.0.1"
      },
      "streamSettings": {
        "sockopt": {
          "tcpKeepAliveInterval": 1,
          "tcpKeepAliveIdle": 11
        }
      }
    },
	{
      "port": 11666,
      "tag": "tls-decrypt-h11",
      "protocol": "tunnel",
      "settings": {
        "network": "tcp",
        "port": 443,
        "followRedirect": true
      },
      "streamSettings": {
        "security": "tls",
        "tlsSettings": {
          "alpn": ["http/1.1"],
          "certificates": [
            {
              "usage": "issue",
              "certificateFile": "mycert.crt",
              "keyFile": "mycert.key"
            }
          ]
        }
      }
    },
    {
      "port": 11777,
      "tag": "tls-decrypt-h211",
      "protocol": "tunnel",
      "settings": {
        "network": "tcp",
        "port": 443,
        "followRedirect": true
      },
      "streamSettings": {
        "security": "tls",
        "tlsSettings": {
          "alpn": ["h2","http/1.1"],
          "certificates": [
            {
              "usage": "issue",
              "certificateFile": "mycert.crt",
              "keyFile": "mycert.key"
            }
          ]
        }
      }
    }
  ],

  "outbounds": [
    {
      "tag": "block",
      "protocol": "block"
    },
	{
      "tag": "direct",
      "protocol": "direct",
      "streamSettings": {
        "sockopt": {
          "domainStrategy": "ForceIP",
          "happyEyeballs": {
            "tryDelayMs": 300,
            "prioritizeIPv6": false,
            "interleave": 2,
            "maxConcurrentTry": 20
          }
        }
      }
	},
    {
      "tag": "dns-out",
      "protocol": "dns",
      "settings": {"nonIPQuery": "reject", "blockTypes": [0, 65]}
    },
	{
      "tag": "redirect-out-h11",
      "protocol": "direct",
      "settings": {
        "redirect": "127.0.0.1:11666",
		"ipsBlocked": []
      }
    },
    {
      "tag": "redirect-out-h211",
      "protocol": "direct",
      "settings": {
        "redirect": "127.0.0.1:11777",
		"ipsBlocked": []
      }
    },
	{
      "tag": "tls-repack-googlevideo",
      "protocol": "direct",
      "streamSettings": {
        "security": "tls",
        "tlsSettings": {
          "serverName": "www.google.com",
          "verifyPeerCertByName": "fromMitM,www.google.com,dns.google,www.googlevideo.com,www.youtube.com",
          "alpn": ["fromMitM"],
          "fingerprint": "chrome"
        },
		"sockopt": {
          "domainStrategy": "ForceIP",
          "happyEyeballs": {
            "tryDelayMs": 300,
            "prioritizeIPv6": false,
            "interleave": 2,
            "maxConcurrentTry": 20
          }
        }
      }
    },
    {
      "tag": "tls-repack-google-main-services",
      "protocol": "direct",
      "settings": {
        "redirect": "google-main-services.redirect:443"
      },
      "streamSettings": {
        "security": "tls",
        "tlsSettings": {
          "serverName": "www.google.com",
          "verifyPeerCertByName": "fromMitM,www.google.com,dns.google,www.googlevideo.com,www.youtube.com",
          "alpn": ["fromMitM"],
          "fingerprint": "chrome"
        },
		"sockopt": {
          "domainStrategy": "ForceIP",
          "happyEyeballs": {
            "tryDelayMs": 300,
            "prioritizeIPv6": false,
            "interleave": 2,
            "maxConcurrentTry": 20
          }
        }
      }
    },
	{
      "tag": "tls-repack-vercel-sites",
      "protocol": "direct",
      "settings": {
        "redirect": "vercel-sites.redirect:443"
      },
      "streamSettings": {
        "security": "tls",
        "tlsSettings": {
          "serverName": "react.dev",
          "verifyPeerCertByName": "fromMitM,react.dev,cursor.com,ai-sdk.dev,err.sh,hyper.is,nextjs.org,now.sh,skills.sh,static.fun,title.sh,turborepo.org,vercel-dns.com,vercel-status.com,vercel.app,vercel.blog,vercel.com,vercel.dev,vercel.events,vercel.live,vercel.pub,vercel.sh,vercel.store,zeit-world.co.uk,zeit-world.com,zeit-world.net,zeit-world.org,zeit.co,zeit.sh,zeitworld.com",
          "alpn": ["fromMitM"],
          "fingerprint": "chrome"
        },
		"sockopt": {
          "domainStrategy": "ForceIP",
          "happyEyeballs": {
            "tryDelayMs": 300,
            "prioritizeIPv6": false,
            "interleave": 2,
            "maxConcurrentTry": 20
          }
        }
      }
    },
	{
      "tag": "tls-repack-fastly",
      "protocol": "direct",
      "settings": {
        "redirect": "fastly.redirect:443"
      },
      "streamSettings": {
        "security": "tls",
        "tlsSettings": {
          "serverName": "www.python.org",
          "verifyPeerCertByName": "fromMitM,www.python.org,pypi.org,fastly.com,www.fastly.com,developer.fastly.com,reddit.com,githubassets.com,github.com,github.io,githubusercontent.com",
          "alpn": ["fromMitM"],
          "fingerprint": "chrome"
        },
		"sockopt": {
          "domainStrategy": "ForceIP",
          "happyEyeballs": {
            "tryDelayMs": 300,
            "prioritizeIPv6": false,
            "interleave": 2,
            "maxConcurrentTry": 20
          }
        }
      }
    },
	{
      "tag": "tls-repack-amazon-cloudfront",
      "protocol": "direct",
      "settings": {
        "redirect": "amazon-cloudfront.redirect:443"
      },
      "streamSettings": {
        "security": "tls",
        "tlsSettings": {
          "serverName": "kubernetes.io",
          "verifyPeerCertByName": "fromMitM,kubernetes.io,letsencrypt.org,aws.amazon.com,aws-us-west-2.amazon.com,www.aws.amazon.com,1.aws-lbr.amazonaws.com,amazonaws-china.com,www.amazonaws-china.com,aws-us-east-1.amazon.com",
          "alpn": ["fromMitM"],
          "fingerprint": "chrome"
        },
		"sockopt": {
          "domainStrategy": "ForceIP",
          "happyEyeballs": {
            "tryDelayMs": 300,
            "prioritizeIPv6": false,
            "interleave": 2,
            "maxConcurrentTry": 20
          }
        }
      }
    }
  ],

  "routing": {
    "domainStrategy": "IPOnDemand",
    "rules": [
      {
	   "outboundTag": "block",
       "domain": ["geosite:category-ads-all"]
      },
      {
	   "outboundTag": "direct",
       "inboundTag": ["dns_inbound"], "port": 53
      },
      {
	   "outboundTag": "dns-out",
       "port": 53
      },
      {
	   "outboundTag": "direct",
       "domain": ["domain:ir", "geosite:private", "geosite:category-ir"]
      },
      {
	   "outboundTag": "tls-repack-googlevideo",
       "domain": ["domain:googlevideo.com"],
       "inboundTag": ["tls-decrypt-h11"]
	  },
      {
	   "outboundTag": "tls-repack-google-main-services",
       "domain": ["geosite:google"],
       "inboundTag": ["tls-decrypt-h211"]
	  },
	  {
	   "outboundTag": "tls-repack-vercel-sites",
       "domain": ["geosite:vercel"],
       "inboundTag": ["tls-decrypt-h211"]
	  },
	  {
	   "outboundTag": "tls-repack-fastly",
       "domain": ["geosite:fastly", "geosite:reddit", "domain:githubassets.com", "domain:githubusercontent.com"],
       "inboundTag": ["tls-decrypt-h211"]
	  },
	  {
	   "outboundTag": "tls-repack-amazon-cloudfront",
       "domain": ["geosite:netlify"],
       "inboundTag": ["tls-decrypt-h211"]
	  },
	  {
	   "outboundTag": "tls-repack-fastly",
       "ip": ["geoip:fastly"],
       "inboundTag": ["tls-decrypt-h211"]
	  },
      {
	   "outboundTag": "block",
       "inboundTag": ["tls-decrypt-h211", "tls-decrypt-h11"]
	  },
      {
        "outboundTag": "redirect-out-h11",
        "network": "tcp",
        "port": 443,
        "domain": ["domain:googlevideo.com"]
      },
      {
        "outboundTag": "redirect-out-h211",
        "network": "tcp",
        "port": 443,
        "domain": ["geosite:google", "geosite:vercel", "geosite:fastly", "geosite:reddit", "domain:githubassets.com", "domain:githubusercontent.com", "geosite:netlify"]
      },
      {
	   "outboundTag": "direct",
       "ip": ["geoip:private", "geoip:ir"]
      },
	  {
        "outboundTag": "redirect-out-h211",
        "network": "tcp",
        "port": 443,
        "ip": ["geoip:fastly"]
      },
      {
	   "outboundTag": "direct",
       "port": "0-65535"
      }
    ]
  }
}
